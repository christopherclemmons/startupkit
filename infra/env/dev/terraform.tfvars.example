brand_color       = "#0f766e"

feature_1_title       = "Replace feature one title"
feature_1_description = "Replace feature one description."
feature_2_title       = "Replace feature two title"
feature_2_description = "Replace feature two description."
feature_3_title       = "Replace feature three title"
