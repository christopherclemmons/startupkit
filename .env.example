# Used by docker-compose to name containers
# Example resulting name when APP_NAME is blank: app-postgres
APP_NAME=

# Public branding + canonical frontend URL
SITE_NAME=Terrastack
SITE_URL=http://localhost:3000

# Database credentials/settings (used by Postgres container and API connection string)
POSTGRES_DB=app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_PORT=5332

# API -> DB connection inside Docker network
DB_HOST=postgres
DB_PORT=5432
DB_AUTO_MIGRATE=true

# Frontend -> backend URL used by the Next.js server-side proxy
BACKEND_INTERNAL_URL=http://backend:5000

# pgAdmin login and local port
PGADMIN_DEFAULT_EMAIL=admin@local.dev
PGADMIN_DEFAULT_PASSWORD=change-me
PGADMIN_PORT=5050


